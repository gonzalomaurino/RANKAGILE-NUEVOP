# Node Environment
NODE_ENV=production

# Server Configuration
PORT=8000

# Database (opcional). Si no se configura se usa storage in-memory.
# DATABASE_URL=postgresql://user:pass@host:5432/rankagile

# CORS (configure based on your deployment domain)
# CORS_ORIGIN=https://your-domain.com

# ==================== SEO ANALYZER ====================

# Core Web Vitals reales via Google PageSpeed Insights (free tier con cuenta GCP)
# PAGESPEED_API_KEY=

# Backlinks (opcional)
# MOZ_API_KEY=
# DATAFORSEO_API_KEY=

# User agent del crawler propio
# SEO_USER_AGENT=Mozilla/5.0 (compatible; RankAgileBot/1.0; +https://rankagile.com/bot)

# Timeouts (ms)
# SEO_REQUEST_TIMEOUT_MS=20000
# SEO_ANALYSIS_TIMEOUT_MS=45000

# Caché de resultados SEO
# SEO_CACHE_TTL_MS=86400000
# SEO_CACHE_MAX=500

# Rate limit del free tier
# RATE_LIMIT_FREE=5
# RATE_LIMIT_WINDOW_MS=86400000

# PDF
# PDF_ENABLED=true
