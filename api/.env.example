PORT=3001
NODE_ENV=development

# SMTP — notificación de leads a la casilla de destino
# Ejemplo Gmail (con App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=tu-cuenta@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx  (App Password de Gmail, no la contraseña normal)
# Ejemplo Resend / Mailgun / SendGrid: usar su SMTP relay correspondiente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=RankAgile <no-reply@rankagile.com>
MAIL_TO=growthimbar@gmail.com
